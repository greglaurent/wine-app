# Copy to .env and adjust. docker-compose reads these.
POSTGRES_USER=wine
POSTGRES_PASSWORD=change-me
POSTGRES_DB=wine
APP_PORT=8090
# Host port for Postgres in local dev only (override file). Unused in prod.
POSTGRES_PORT=5432

# Server runtime + local `cargo sqlx` / dev use:
DATABASE_URL=postgres://wine:change-me@localhost:5432/wine
BIND_ADDR=0.0.0.0:8080
